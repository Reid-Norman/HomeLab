# Docker Management Stack Environment Variables
# Generated by Ansible env_files role — do not edit manually.

WATCHTOWER_CLEANUP=true
WATCHTOWER_POLL_INTERVAL=300
{% if vault_telegram_bot_token is defined and vault_telegram_bot_token and not vault_telegram_bot_token.startswith('REPLACE_') %}
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=telegram://{{ vault_telegram_bot_token }}@telegram?channels={{ vault_telegram_chat_id }}
{% else %}
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=
{% endif %}

DOMAIN={{ vault_domain }}
