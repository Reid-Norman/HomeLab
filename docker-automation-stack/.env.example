# Docker Automation Stack Environment Variables
# Copy to .env and fill in real values, or use `make ansible-sync` to generate from vault.

# Semaphore
SEMAPHORE_SECRET_KEY=replace_with_secret

# Semaphore Admin (only used on first run to create the admin account)
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@example.com
SEMAPHORE_ADMIN_PASSWORD=replace_with_admin_password

# PostgreSQL
SEMAPHORE_DB_NAME=semaphore
SEMAPHORE_DB_USER=semaphore
SEMAPHORE_DB_PASS=replace_with_db_password

DOMAIN=hightechlowlife.ca
