# Ansible Vault secrets placeholder
# Copy to vault.yml and encrypt: ansible-vault encrypt vault.yml
# Edit with: make vault-edit
# Or generate all credentials: make generate-creds STACK=all

# --- Common (user-provided via generate-creds common) ---
vault_domain: "example.com"
vault_server_ip: "192.168.1.100"
vault_le_email: "REPLACE_LE_EMAIL"

# --- Networking (generate-creds networking) ---
# Auto-generated: htpasswd hash
vault_traefik_dashboard_password: "REPLACE_WITH_HTPASSWD_OUTPUT"
# User-provided: Cloudflare credentials
vault_cf_api_email: "REPLACE_CF_API_EMAIL"
vault_cf_dns_api_token: "REPLACE_CF_DNS_API_TOKEN"

# --- Management (generate-creds management) ---
# Auto-generated
adguard_username: "REPLACE_ADGUARD_USERNAME"
adguard_password: "REPLACE_ADGUARD_PASSWORD"
vault_uptime_kuma_username: "REPLACE_UPTIME_KUMA_USER"
vault_uptime_kuma_password: "REPLACE_UPTIME_KUMA_PASS"

# --- Media (generate-creds media) ---
# User-provided: VPN credentials
vault_vpn_service_provider: "pia"
vault_openvpn_user: "REPLACE_VPN_USER"
vault_openvpn_password: "REPLACE_VPN_PASSWORD"
# (Cloudflare tunnel token removed — now uses locally-managed tunnel with credentials file)
# Auto-generated
qbittorrent_username: "REPLACE_QBT_USER"
qbittorrent_password: "REPLACE_QBT_PASS"

# --- Automation / Semaphore (generate-creds semaphore) ---
# Auto-generated
vault_semaphore_secret_key: "REPLACE_SEMAPHORE_SECRET"
vault_semaphore_admin_user: "admin"
vault_semaphore_admin_name: "Admin"
vault_semaphore_admin_email: "REPLACE_ADMIN_EMAIL"
vault_semaphore_admin_password: "REPLACE_SEMAPHORE_ADMIN_PASSWORD"
vault_semaphore_db_password: "REPLACE_SEMAPHORE_DB_PASSWORD"

# --- Telegram notifications (optional — generate-creds common) ---
vault_telegram_bot_token: "REPLACE_TELEGRAM_BOT_TOKEN"
vault_telegram_chat_id: "REPLACE_TELEGRAM_CHAT_ID"

# --- Cloudflare Tunnel (generate-creds media) ---
vault_cloudflare_tunnel_id: "REPLACE_TUNNEL_UUID"
vault_cloudflare_tunnel_credentials: "REPLACE_TUNNEL_CREDENTIALS_JSON"
vault_cloudflare_account_id: "REPLACE_CLOUDFLARE_ACCOUNT_ID"
vault_cloudflare_zone_id: "REPLACE_CLOUDFLARE_ZONE_ID"

# --- Post-deployment (extract-api-keys.sh) ---
# Extracted from running containers after first deploy
radarr_api_key: "REPLACE_WITH_RADARR_API_KEY"
sonarr_api_key: "REPLACE_WITH_SONARR_API_KEY"
prowlarr_api_key: "REPLACE_WITH_PROWLARR_API_KEY"
# Jellyfin admin (user-provided: used by Jellyseerr role + future Jellyfin role)
vault_jellyfin_username: "REPLACE_JELLYFIN_USER"
vault_jellyfin_email: "REPLACE_JELLYFIN_EMAIL"
vault_jellyfin_password: "REPLACE_JELLYFIN_PASS"
vault_jellyfin_api_key: "REPLACE_JELLYFIN_API_KEY"
