# Docker Media Stack Environment Variables
# Generated by Ansible env_files role — do not edit manually.

# VPN Configuration
VPN_SERVICE_PROVIDER={{ vault_vpn_service_provider }}
OPENVPN_USER={{ vault_openvpn_user }}
OPENVPN_PASSWORD={{ vault_openvpn_password }}
VPN_TYPE=openvpn
SERVER_COUNTRIES=Canada
SERVER_REGIONS=CA Ontario
PRIVATE_INTERNET_ACCESS_OPENVPN_ENCRYPTION_PRESET=strong
VPN_PORT_FORWARDING=on
PORT_FORWARD_ONLY=true

# Docker Network
MY_NETWORK=homelab-network
DNS_SERVERS=1.1.1.1,8.8.8.8
RADARR_STATIC_CONTAINER_IP=172.20.0.10
SONARR_STATIC_CONTAINER_IP=172.20.0.11

# Common Environment Variables
PUID=1000
PGID=1000
TZ=UTC

# Recommendarr
RECOMMENDARR_PUBLIC_URL=https://recommendarr.{{ vault_domain }}

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN={{ vault_cloudflare_tunnel_token }}

# Let's Encrypt / Domain
LE_EMAIL={{ vault_le_email }}
DOMAIN={{ vault_domain }}
