# Docker Media Stack Environment Variables
# Copy to .env and fill in real values, or use `make ansible-sync` to generate from vault.

# VPN Configuration
VPN_SERVICE_PROVIDER=pia
OPENVPN_USER=your_vpn_username
OPENVPN_PASSWORD=your_vpn_password
VPN_TYPE=openvpn
SERVER_COUNTRIES=Canada
SERVER_REGIONS=CA Ontario
PRIVATE_INTERNET_ACCESS_OPENVPN_ENCRYPTION_PRESET=strong
VPN_PORT_FORWARDING=on
PORT_FORWARD_ONLY=true

# Docker Network
MY_NETWORK=homelab-network
DNS_SERVERS=1.1.1.1,8.8.8.8
RADARR_STATIC_CONTAINER_IP=172.20.0.200
SONARR_STATIC_CONTAINER_IP=172.20.0.201

# Common Environment Variables
PUID=1000
PGID=1000
TZ=UTC

# Recommendarr
RECOMMENDARR_PUBLIC_URL=https://recommendarr.example.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Let's Encrypt / Domain
LE_EMAIL=your_email@example.com
DOMAIN=example.com
