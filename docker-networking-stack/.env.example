# Docker Networking Stack Environment Variables
# Copy to .env and fill in real values, or use `make ansible-sync` to generate from vault.

# Traefik
DOMAIN=example.com
LE_EMAIL=your_email@example.com
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token
CF_API_EMAIL=your_cloudflare_email@example.com
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$...  # output of: htpasswd -nbB admin yourpassword
